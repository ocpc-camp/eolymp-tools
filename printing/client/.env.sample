# Absolute path to gswin32.exe (Windows only). Leave empty on Linux/macOS.
GHOSTSCRIPT_PATH=
# Absolute path to gsprint.exe (Windows only). Leave empty on Linux/macOS.
GSPRINT_PATH=

# Numeric ID of this physical printer. Should match the value of the
# `room` attribute of members whose jobs should be printed here.
# Use 1 if you are not using per-room routing.
PHYSICAL_PRINTER_ID=1

# Name of the local printer as the OS sees it (Windows: from "Devices and
# Printers"). Ignored on Linux/macOS, where the system default printer is
# used by `lp`.
PHYSICAL_PRINTER_NAME=

# Eolymp access key (NOT a regular OAuth token — this client runs for hours).
# Required scopes: printer:printer:read printer:printer:write
#                  universe:space:read community:member:read
EOLYMP_TOKEN=CHANGE_ME

# Short name of the Eolymp space, e.g. "myevent2026".
EOLYMP_SPACE=CHANGE_ME

# ID of the (single) Eolymp printer for this space — the random string
# in the printer's URL in the admin console.
EOLYMP_PRINTER_ID=CHANGE_ME
